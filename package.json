{
  "name": "coding-agent-visualizer",
  "version": "0.1.3",
  "type": "module",
  "description": "Local visualizer for Claude Code, Codex, Gemini, OpenCode, Cursor and Cline agent transcripts.",
  "homepage": "https://github.com/everettjf/coding-agent-visualizer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everettjf/coding-agent-visualizer.git"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "codex",
    "gemini",
    "coding-agent",
    "visualizer",
    "llm",
    "observability"
  ],
  "bin": {
    "coding-agent-visualizer": "src/cli.ts",
    "cav": "src/cli.ts"
  },
  "files": [
    "src",
    "bunfig.toml",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "bun src/server/index.ts",
    "build": "bun build src/frontend/index.html --outdir dist",
    "build:demo": "bun build src/frontend/demo.html --outdir docs/demo --public-path ./",
    "compile": "bun build --compile --minify --outfile dist/coding-agent-visualizer src/server/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "release": "bun scripts/release.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.3.5",
    "bun-plugin-tailwind": "^0.1.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "lucide-react": "^1.18.0",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.7.0"
  }
}
